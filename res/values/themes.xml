<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Bizvault" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main Palette -->
        <item name="colorPrimary">@color/accent_cyan</item>
        <item name="colorOnPrimary">@color/primary_dark</item>
        <item name="colorSecondary">@color/accent_cyan</item>
        <item name="colorOnSecondary">@color/primary_dark</item>
        <item name="colorTertiary">@color/accent_cyan</item>
        
        <!-- Backgrounds -->
        <item name="android:windowBackground">@color/primary_dark</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/primary_dark</item>

        <!-- Components -->
        <item name="materialButtonStyle">@style/Widget.BizVault.Button</item>
        <item name="textInputStyle">@style/Widget.BizVault.TextInputLayout</item>
    </style>

    <style name="Theme.Bizvault" parent="Base.Theme.Bizvault" />

    <!-- Modern Button Style -->
    <style name="Widget.BizVault.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent_cyan</item>
        <item name="android:textColor">@color/primary_dark</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Refined Text Input Style -->
    <style name="Widget.BizVault.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/accent_cyan</item>
        <item name="hintTextColor">@color/accent_cyan</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- Dropdown Menu Style -->
    <style name="Widget.BizVault.ExposedDropdownMenu" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxStrokeColor">@color/accent_cyan</item>
        <item name="hintTextColor">@color/accent_cyan</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="endIconTint">@color/accent_cyan</item>
    </style>
</resources>